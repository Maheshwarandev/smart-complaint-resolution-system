# Backend configuration example
# Copy this file to .env and fill in your actual values

PORT=5000
NODE_ENV=development

# MongoDB connection URI
# For local MongoDB:
MONGO_URI=mongodb://127.0.0.1:27017/scrs_db
# For MongoDB Atlas, use:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/scrs_db

# JWT configuration
# Generate a strong secret key (use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your_super_long_random_secret_key_change_this_in_production

# Optional: token expiration time (default: 30d)
JWT_EXPIRES_IN=30d

# Frontend URL for CORS (required in production)
# Leave empty in development to allow http://localhost:3000
# Set to your production frontend URL in production
FRONTEND_URL=https://your-frontend-domain.com
